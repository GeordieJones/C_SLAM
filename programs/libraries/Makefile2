CC = gcc

# Optimization flags and include headers search paths
CFLAGS = -O3 -Wall -Wextra \
         -I. \
         -I../../neural_network/libraries \
         -I../../computer_vision/libraries

CFLAGS += -g -O2
CFLAGS += -no-pie

# Linker flags including Math library and structural FFmpeg codec suites
LDFLAGS = -lm -lavcodec -lavformat -lavutil -lswscale

# Core Computer Vision components requested from the CV repository
SRC_CV = ../../computer_vision/libraries/auto_labeler.c \
         ../../computer_vision/libraries/image_decoders.c \
         ../../computer_vision/libraries/raycasting.c \
         ../../computer_vision/libraries/scene_graph.c \
         ../../computer_vision/libraries/slam_math.c \
         ../../computer_vision/libraries/point_cloud.c

# Core Neural Network layers
SRC_NN = ../../neural_network/libraries/trainer.c \
         ../../neural_network/libraries/layer.c \
         ../../neural_network/libraries/network.c \
         ../../neural_network/libraries/dataset.c \
         ../../neural_network/libraries/tensor.c \
         ../../neural_network/libraries/activation.c

# Your execution engine files
SRC_PIPELINE = distance_detection_run.c pipelines.c

# Consolidated dependency list containing all actual implementation files
SRC_COMMON = $(SRC_PIPELINE) $(SRC_CV) $(SRC_NN)

TARGET = run_slam

all: $(TARGET)

$(TARGET): $(SRC_COMMON)
	# Compiles all .c source files directly and links against FFmpeg libraries
	$(CC) $(CFLAGS) $(SRC_COMMON) $(LDFLAGS) -o $(TARGET)

clean:
	rm -f $(TARGET)
